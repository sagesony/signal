{
  "manifest_version": 3,
  "name": "Signal – Meta Ad Sync",
  "version": "1.0.1",
  "description": "Sync competitor ads from Meta Ad Library directly into Signal.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "*://www.facebook.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.facebook.com/ads/library/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["interceptor.js"],
      "matches": ["*://www.facebook.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Signal Ad Sync"
  }
}
